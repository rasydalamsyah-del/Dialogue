"55": {
&"character": "Mabel",
&"id": "55",
&"next_id": "56",
&"text": "Omg shush you're making me blush 😊",
&"type": "dialogue"
},
"56": {
&"character": "Mabel",
&"id": "56",
&"next_id": "57",
&"text": "I was just teasing you",
