},
"57": {
&"character": "Mabel",
&"id": "57",
&"next_id": "58",
&"text": "Why'd you have to be all cute suddenly 🫣",
&"type": "dialogue"
},
"58": {
&"character": "Player",
&"id": "58",
&"next_id": "59",
&"text": "Mission accomplished hehe",
&"type": "dialogue"
},
