&"id": "10",
&"next_id": "11",
&"text": "Mom??",
&"type": "dialogue"
},
"100": {
&"character": "Mom",
&"id": "100",
&"next_id": "101",
&"text": "I promise we'll talk soon",
&"type": "dialogue"
},
"101": {
&"character": "PlayerM",
&"id": "101",
&"next_id": "102",
&"text": "Fine 😩 I miss you so much",
&"type": "dialogue"
},
"102": {
&"character": "Mom",
&"id": "102",
&"next_id": "103",
&"text": "Awwh I miss you too!",
&"type": "dialogue"
},
"103": {
&"character": "Mom",
&"id": "103",
&"next_id": "104",
&"text": "Love you baby ❤️",
&"type": "dialogue"
},
"104": {
&"character": "PlayerM",
&"id": "104",
&"next_id": "105",
&"text": "Love you too Mom 🥰",
&"type": "dialogue"
},
