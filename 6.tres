raw_text = "~ start
do Story.set_location(\"mabels_room\")
do social_post(\"collegelife_clubreg\")
Mabel: DONEE
Mabel: Yippeee
Mabel: First week is over 🥳
Player: Same, can catch our breath now
Mabel: 😮‍💨
Mabel: I can't wait for tomorrow 🥰
Mabel: Are you as excited as I am??
Player: Mhmm!
Mabel: Naomi told me she texted you this morning!
Mabel: So? What did you think??
- She seems nice! [#trust]
	set Story.mabel_trust += 1
	Player: She seems nice!
	Mabel: Right?? You'll see she's so polite and easy to talk to in person
- It was alright
	Player: It was alright
do social_post(\"naomi_spank\")
Mabel: I can't wait for you to meet them hehe
Mabel: Well I haven't met ALL of them either but y'know! 😁
Mabel: I'm a little flustered already too
Player: You've become quite social in only 2 weeks
Mabel: 😳
Mabel: No way.
Mabel: Really?
Player: Really really 😂
Mabel: I think you're right
Mabel: But I can't stop smiling for some reason hehe
if Story.mabel_desire <= 0:
	Mabel: I wish you were here
	Mabel: Lying right next to me 🤭
	Player: Me too 😍
	Mabel: I feel like I could pass out right here right now
	Mabel: I'd want you to be right next to me when I fall asleep and wake up 🥰
	Mabel: Thought: Maybe you could massage my sore butt a little too hehe
	Mabel: Do I look silly? 🤪😂
	Player: Cute!
	Mabel: Gee 🥰
Mabel: Speaking of all this
Mabel: Club invites are going out next week!
Mabel: CollegeLife recommends that we join one
Player: Any ideas on which one you think you're applying to?
Mabel: Hmm what do you think? I think the answer is totally obvious! 😌
- Photography Club? [#trust]
	set Story.mabel_trust += 1
	Player: Photography Club?
	Mabel: Mhmm!
	Mabel: I plan on it!
- Sorority right? [#distrust]
	set Story.mabel_trust -= 1
	Player: Sorority right?
	Mabel: Wait you thought?
	Mabel: Seriously? 😅
	Mabel: You think I'd be a good match there? Idk
	Mabel: I know Nina wants me to join
Mabel: Well I haven't decided yet but we'll see!
Mabel: I better hurry up and decide then 🥰
Mabel: What about you?
Player: Might be hard with work but I'll see too
Mabel: Oh right!
Mabel: You're such a hard worker when you put your mind to it 🥰
Mabel: Okay then, I'll do some homework now!
Mabel: I want the weekend to be free!
Mabel: Ttyl okay?
Player: Gn gn!
Mabel: Gn
=> END"
metadata/dialogue_manager_version = "3.7.1"
