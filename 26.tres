&"character": "Jessica",
&"id": "130",
&"next_id": "131",
&"text": "Lets say \"personal\" use. The slut will move into her new man's room and become his personal bitch for the rest of her college years",
&"type": "dialogue"
},
"131": {
&"character": "Jason",
&"id": "131",
&"next_id": "132",
&"text": "Can they refuse? 🤔",
