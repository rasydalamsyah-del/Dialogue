&"character": "Erika",
&"id": "4",
&"next_id": "5",
&"text": "Out of all the girls you could've chosen too",
&"type": "dialogue"
},
"40": {
&"character": "Erika",
&"id": "40",
&"next_id": "41",
&"text": "In fact, I want quite the opposite 🥰",
