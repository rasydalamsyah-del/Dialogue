},
"39": {
&"character": "Mabel",
&"id": "39",
&"next_id": "40",
&"text": "Thought: They give me really weird looks",
&"type": "dialogue"
},
"4": {
&"character": "Player",
&"id": "4",
&"next_id": "5",
&"text": "How was your day??",
&"type": "dialogue"
},
"40": {
&"character": "Mabel",
&"id": "40",
&"next_id": "41",
&"text": "Thought: I think one of them was drooling",
&"type": "dialogue"
},
"41": {
&"character": "Mabel",
&"id": "41",
&"next_id": "42",
&"text": "Thought: Did he want to steal my lunch or something?",
&"type": "dialogue"
},
"42": {
&"character": "Mabel",
&"id": "42",
&"next_id": "43",
&"text": "I'd... rather not if I don't have to 🙂",
&"type": "dialogue"
},
"43": {
&"character": "Mabel",
&"id": "43",
&"next_id": "44",
&"text": "I was like wow you went all that way? 🥺 For me?",
&"type": "dialogue"
},
"44": {
&"character": "Mabel",
&"id": "44",
&"next_id": "45",
&"text": "I might have cried if I wasn't so shy of meeting a new girl 😇",
&"type": "dialogue"
},
"45": {
&"character": "Mabel",
&"id": "45",
&"next_id": "46",
&"text": "Anyway! We had lunch together and she asked me about everything 😊",
&"type": "dialogue"
},
