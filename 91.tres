"24": {
&"character": "Mabel",
&"id": "24",
&"next_id": "25",
&"text": "She wasn't a student in my class buuut",
&"type": "dialogue"
},
"25": {
&"character": "Mabel",
&"id": "25",
&"next_id": "26",
&"text": "After class, Prof Suzanna called me up to ask if everything was okay 🥰",
&"type": "dialogue"
},
