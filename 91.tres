},
"100": {
&"character": "Mabel",
&"id": "100",
&"next_id": "101",
&"text": "I'm too tired for your teasing me right now 😂",
&"type": "dialogue"
},
"101": {
&"character": "Player",
&"id": "101",
&"next_id": "102",
&"text": "Who took the picture?",
&"type": "dialogue"
},
"102": {
&"character": "Mabel",
&"id": "102",
&"next_id": "103",
&"text": "Oh! Right, there was a guy with her",
&"type": "dialogue"
},
"103": {
&"character": "Mabel",
&"id": "103",
&"next_id": "104",
&"text": "I didn't notice him at first!!",
&"type": "dialogue"
},
"104": {
&"character": "Mabel",
&"id": "104",
&"next_id": "105",
&"text": "He was really quiet and I just thought he was another student",
&"type": "dialogue"
},
"105": {
&"character": "Mabel",
&"id": "105",
&"next_id": "106",
&"text": "We even had lunch and he was just sort of in the background 😅",
&"type": "dialogue"
},
"106": {
&"character": "Mabel",
&"id": "106",
&"next_id": "107",
&"text": "It was funny cause he was quite tall 😅 Like how didn't I notice him at all??",
&"type": "dialogue"
},
"107": {
&"character": "Player",
&"id": "107",
&"next_id": "108",
&"text": "Oh interesting 🤔",
&"type": "dialogue"
},
"108": {
&"character": "Mabel",
&"id": "108",
&"next_id": "109",
&"text": "Isn't it?",
&"type": "dialogue"
},
"109": {
&"character": "Mabel",
&"id": "109",
&"next_id": "110",
&"text": "He had a camera with him and he was took the pictures",
&"type": "dialogue"
},
"11": {
&"id": "11",
&"next_id": "12",
&"tags": PackedStringArray("lust"),
&"text": "I'd like to see that",
&"type": "response"
},
"110": {
&"character": "Mabel",
&"id": "110",
&"next_id": "111",
&"text": "Naomi was so sweet to him but he was all shy quiet and blushy",
&"type": "dialogue"
},
"111": {
&"character": "Mabel",
&"id": "111",
&"next_id": "112",
&"text": "I think she didn't want to push him",
&"type": "dialogue"
},
"112": {
&"character": "Mabel",
&"id": "112",
&"next_id": "113",
&"text": "But that's when I kind of realized that they might be dating",
&"type": "dialogue"
},
"113": {
&"character": "Player",
&"id": "113",
&"next_id": "114",
&"text": "You didn't ask?",
&"type": "dialogue"
},
"114": {
&"character": "Mabel",
&"id": "114",
&"next_id": "115",
&"text": "No! I didn't want to sound like I'm assuming anything",
&"type": "dialogue"
},
"115": {
&"character": "Mabel",
&"id": "115",
&"next_id": "116",
&"text": "But I wish you were following me around like he was following her 🥹",
&"type": "dialogue"
},
"116": {
&"character": "Mabel",
&"id": "116",
&"next_id": "117",
&"text": "I seriously need you by my side always",
&"type": "dialogue"
},
"117": {
&"character": "Mabel",
&"id": "117",
&"next_id": "118",
&"text": "I could imagine it being her boyfriend 😊",
&"type": "dialogue"
},
