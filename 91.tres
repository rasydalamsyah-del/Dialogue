},
"191": {
&"character": "Mabel",
&"id": "191",
&"next_id": "192",
&"text": "I feel like there's too much going on here!",
&"type": "dialogue"
},
"192": {
&"character": "Mabel",
&"id": "192",
&"next_id": "211",
&"text": "I'm usually smiley back at home but now I just feel like this all the time",
&"type": "dialogue"
},
"193": {
&"id": "193",
&"next_id": "194",
&"text": "What did you guys talk about?",
