},
"3": {
&"character": "Player",
&"id": "3",
&"next_id": "4",
&"text": "Welcome back!",
&"type": "dialogue"
},
"30": {
&"character": "Mabel",
&"id": "30",
&"next_id": "31",
&"text": "Okay so her name is Naomi!",
&"type": "dialogue"
},
"31": {
&"character": "Mabel",
&"id": "31",
&"next_id": "32",
&"text": "She said she was in photography club, looking for members",
&"type": "dialogue"
},
"32": {
&"character": "Mabel",
&"id": "32",
&"next_id": "33",
&"text": "Ms Suzanna called her in because she said I might have difficulty socializing in a boys only class on my first year 😆",
&"type": "dialogue"
},
"33": {
&"id": "33",
&"next_id": "34",
&"responses": PackedStringArray("33", "36"),
&"text": "She's got a point!",
&"type": "response"
},
"34": {
&"character": "Player",
&"id": "34",
&"next_id": "35",
&"text": "She's got a point!",
&"type": "dialogue"
},
"35": {
&"character": "Mabel",
&"id": "35",
&"next_id": "43",
&"text": "Right? Anyway!",
&"type": "dialogue"
},
"36": {
&"id": "36",
&"next_id": "37",
&"tags": PackedStringArray("distrust"),
&"text": "Why not try socializing with them?",
