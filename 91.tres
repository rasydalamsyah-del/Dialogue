},
"13": {
&"character": "Player",
&"id": "13",
&"next_id": "14",
&"text": "I'd like to see that",
&"type": "dialogue"
},
"130": {
&"character": "Mabel",
&"id": "130",
&"next_id": "131",
&"text": "Thought: Oh my god I am SO corny and lame",
&"type": "dialogue"
},
"131": {
&"character": "Mabel",
&"id": "131",
&"next_id": "132",
&"text": "What if I asked you if Naomi was cute??",
&"type": "dialogue"
},
"132": {
&"id": "132",
&"next_id": "133",
&"responses": PackedStringArray("132", "167"),
&"text": "I'd be honest about it and say yes",
&"type": "response"
},
"133": {
&"character": "Player",
&"id": "133",
&"next_id": "134",
&"text": "I'd be honest about it and say yes",
&"type": "dialogue"
},
"134": {
&"character": "Mabel",
&"id": "134",
&"next_id": "135",
&"text": "Uhm... okay well",
&"type": "dialogue"
},
"135": {
&"character": "Mabel",
&"id": "135",
&"next_id": "136",
&"text": "I don't think we ever talked about something like that",
&"type": "dialogue"
},
"136": {
&"character": "Mabel",
&"id": "136",
&"next_id": "137",
&"text": "But is this normal to talk about?",
