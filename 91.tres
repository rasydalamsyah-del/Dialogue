},
"128": {
&"character": "Mabel",
&"id": "128",
&"next_id": "129",
&"text": "Maybe a little!",
&"type": "dialogue"
},
"129": {
&"character": "Mabel",
&"id": "129",
&"next_id": "130",
&"text": "But what's point of asking that kind of question when we're together and you're my one and only 🥹",
