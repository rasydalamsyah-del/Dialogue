&"character": "Mabel",
&"id": "46",
&"next_id": "47",
&"text": "At first I gave like one word answers, omg",
&"type": "dialogue"
},
"47": {
&"character": "Mabel",
&"id": "47",
&"next_id": "48",
&"text": "I must have been so boring to talk to 😓",
&"type": "dialogue"
},
"48": {
&"character": "Mabel",
&"id": "48",
&"next_id": "49",
&"text": "Then after like an hour",
