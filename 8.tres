},
"111": {
&"character": "Mabel",
&"id": "111",
&"next_id": "112",
&"text": "Thought: That cute couple were really kissing out in the open",
&"type": "dialogue"
},
"112": {
&"character": "Mabel",
&"id": "112",
&"next_id": "113",
&"text": "Thought: Is that going to be us one day?",
