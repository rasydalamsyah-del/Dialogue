"101": {
&"character": "Player",
&"id": "101",
&"next_id": "102",
&"text": "I wonder if she'd be interested in dating a student",
&"type": "dialogue"
},
"102": {
&"character": "Caleb",
&"id": "102",
&"next_id": "103",
&"text": "Oh, I have no idea",
&"type": "dialogue"
},
"103": {
&"character": "Caleb",
&"id": "103",
&"next_id": "104",
&"text": "I don't know how I'd ask her about that so maybe you could ask her yourself",
&"type": "dialogue"
},
"104": {
&"character": "Caleb",
&"id": "104",
&"next_id": "115",
&"text": "I just always assumed not",
&"type": "dialogue"
},
"105": {
&"id": "105",
&"next_id": "106",
&"text": "That's really cool",
&"type": "response"
},
"106": {
&"character": "Player",
&"id": "106",
&"next_id": "107",
&"text": "That's really cool",
&"type": "dialogue"
},
"107": {
&"character": "Caleb",
&"id": "107",
&"next_id": "108",
&"text": "You think so?",
&"type": "dialogue"
},
"108": {
&"character": "Caleb",
&"id": "108",
&"next_id": "109",
&"text": "A lot of other groups think we're a super lame club",
&"type": "dialogue"
},
"109": {
&"character": "Caleb",
&"id": "109",
&"next_id": "115",
&"text": "I'm glad you think otherwise!",
&"type": "dialogue"
},
"11": {
&"character": "Caleb",
&"id": "11",
&"next_id": "12",
&"text": "Actually she was supposed to text you but she got caught up with work 😅",
&"type": "dialogue"
},
"110": {
&"id": "110",
&"next_id": "111",
&"text": "Is she a part of the club?",
&"type": "response"
},
"111": {
&"character": "Player",
&"id": "111",
&"next_id": "112",
&"text": "Is she a part of the club?",
&"type": "dialogue"
},
"112": {
&"character": "Caleb",
&"id": "112",
&"next_id": "113",
&"text": "Well sort of",
&"type": "dialogue"
},
"113": {
&"character": "Caleb",
&"id": "113",
&"next_id": "114",
&"text": "Clubs are usually funded by a faculty member so she backs us",
&"type": "dialogue"
},
"114": {
&"character": "Caleb",
&"id": "114",
&"next_id": "115",
&"text": "She's really kind to us, hopefully you'll meet her next time",
&"type": "dialogue"
},
"115": {
&"character": "Player",
&"id": "115",
&"next_id": "116",
&"text": "Thanks for sharing!",
&"type": "dialogue"
},
"116": {
&"character": "Caleb",
&"id": "116",
&"next_id": "117",
&"text": "Was there anything else?",
&"type": "dialogue"
},
"117": {
&"id": "117",
&"next_id": "118",
&"responses": PackedStringArray("117", "121"),
&"text": "Do you have a Social acc I could follow?",
&"type": "response"
},
