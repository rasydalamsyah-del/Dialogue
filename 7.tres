"20": {
&"character": "Caleb",
&"id": "20",
&"next_id": "21",
&"text": "I had to use an old film that had a bit of space left on it",
&"type": "dialogue"
},
"21": {
&"character": "Caleb",
&"id": "21",
&"next_id": "22",
&"text": "A lot of them came out nice so I'll forward what I have 😊",
&"type": "dialogue"
},
"22": {
&"character": "Player",
&"id": "22",
&"next_id": "23",
&"text": "Awesome, lets see",
