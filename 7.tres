"35": {
&"character": "Caleb",
&"id": "35",
&"next_id": "36",
&"text": "Alice actually sat down with us for a bit today 🙂",
&"type": "dialogue"
},
"36": {
&"character": "Caleb",
&"id": "36",
&"next_id": "37",
&"text": "Naomi begged her to meet Mabel",
&"type": "dialogue"
},
"37": {
&"character": "Caleb",
&"id": "37",
&"next_id": "38",
&"text": "She had a good feeling about them becoming friends I guess!",
&"type": "dialogue"
},
"38": {
&"character": "Player",
&"id": "38",
&"next_id": "39",
&"text": "She didn't say much",
&"type": "dialogue"
},
"39": {
&"character": "Caleb",
&"id": "39",
&"next_id": "40",
&"text": "Yeah.. Alice is not much of a talker",
&"type": "dialogue"
},
"4": {
&"character": "Caleb",
&"id": "4",
&"next_id": "5",
&"text": "Thanks for coming this afternoon",
&"type": "dialogue"
},
"40": {
&"character": "Player",
&"id": "40",
&"next_id": "41",
&"text": "Is she part of your photography club?",
