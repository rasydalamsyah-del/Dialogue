},
"24": {
&"character": "Player",
&"id": "24",
&"next_id": "25",
&"text": "They had a really good time",
&"type": "dialogue"
},
"25": {
&"character": "Caleb",
&"id": "25",
&"next_id": "26",
&"text": "I'm glad Mabel and Naomi are clicking well together",
&"type": "dialogue"
},
"26": {
&"character": "Caleb",
&"id": "26",
&"next_id": "27",
&"text": "I feel like it's been a while since the clubhouse was this lively",
&"type": "dialogue"
},
"27": {
&"character": "Caleb",
&"id": "27",
&"next_id": "28",
&"text": "It's usually a lot more quiet",
&"type": "dialogue"
},
"28": {
&"character": "Player",
&"id": "28",
&"next_id": "29",
&"text": "Why's that?",
&"type": "dialogue"
},
"29": {
&"character": "Caleb",
&"id": "29",
&"next_id": "30",
&"text": "Just not as many members as before",
&"type": "dialogue"
},
"3": {
&"character": "Caleb",
&"id": "3",
&"next_id": "4",
&"text": "Hey friend! 👋",
&"type": "dialogue"
},
"30": {
&"character": "Caleb",
&"id": "30",
&"next_id": "31",
&"text": "There's been a bit of gossip about us and we've had trouble getting new members since then 😓",
&"type": "dialogue"
},
"31": {
&"character": "Caleb",
&"id": "31",
&"next_id": "32",
&"text": "Anyway, I don't want to be a downer!",
&"type": "dialogue"
},
"32": {
&"character": "Caleb",
&"id": "32",
&"next_id": "33",
&"text": "Especially after the two had a really good time!",
&"type": "dialogue"
},
