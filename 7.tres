},
"42": {
&"character": "Caleb",
&"id": "42",
&"next_id": "43",
&"text": "She's had a pretty bad college experience so far 😞",
&"type": "dialogue"
},
"43": {
&"character": "Caleb",
&"id": "43",
&"next_id": "44",
&"text": "Sorority girls really pick on her hard because of her appearance",
&"type": "dialogue"
},
