raw_text = "~ start
do Story.set_location(\"mabels_room\")
if Story.has_flag(\"Naomi1\"):
	Mabel: Are you there babe? 🙃
	Player: Hey, yeah I'm here
	Mabel: So you're going with Naomi huh?
	Mabel: I heard all the details 🥺
	Player: Yeah 😅
	Player: I heard them just recently too
	Mabel: I asked if I could do the photoshoot instead and she was all like, you sure you wanna do this?
	Mabel: And I have to get naked in front of the camera 😱
	Mabel: So it's kinda... you know.. too much for me 🫣
	Mabel: So I can't really blame you 😭
	Mabel: Naomi was in a tight spot too and I would do anything to help her
	if Story.has_flag(\"LOVE\")
		Mabel: But I still feel a little
		Player: A little what?
		do echo_set([\"113\"])
		Mabel: I'm just a little jealous
		Player: Awwh babe, don't be! 🥺
		Mabel: Thought: Okay maybe super duper max jealous
		Mabel: Don't worry about me 🤧
		Mabel: I'll be fine
		Player: You sure?
		Mabel: I'm sure
		do echo_clear()
	Mabel: Love you for being so helpful too 😚
	Mabel: I'll sort myself out 🤧
	Player: Love you too!
	Mabel: 🩷
	Mabel: But anyway 😊
elif Story.has_flag(\"Suzanna1\"):
	Mabel: Hey babe
	Mabel: Are you home yet?
	Player: Yeah got back about an hour ago
	Mabel: Oo okay
	Mabel: Did you talk to my professor?
	Player: Yeah I did
	Mabel: Well? 
	Mabel: What did she need?
	Player: Well aren't you a nosy one today
	Mabel: 👀
	Player: I just need to go somewhere with her on the weekend
	Mabel: Wow like a secret class or something? 🧐
	Player: Something like that I guess 😆
	Mabel: I see
	Mabel: Thought: So my professor could be an enemy spy afterall..
	Player: 😀
else:
	Mabel: Hey babe
	Mabel: Are you home yet?
	Player: Yeah got back about an hour ago
