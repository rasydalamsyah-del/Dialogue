&"id": "20",
&"next_id": "21",
&"text": "Yeah I saw those messages and went back to my beauty sleep 💅",
&"type": "dialogue"
},
"21": {
&"character": "Player",
&"id": "21",
&"next_id": "22",
&"text": "It was noontime 😳",
