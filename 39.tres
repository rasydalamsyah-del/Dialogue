},
"45": {
&"character": "Paige",
&"id": "45",
&"next_id": "46",
&"text": "Awwh that's sweet 🥺",
&"type": "dialogue"
},
"46": {
&"character": "Paige",
&"id": "46",
&"next_id": "47",
&"text": "Great! So while you're at it, you can pick up my groceries too",
&"type": "dialogue"
},
"47": {
&"character": "Player",
&"id": "47",
&"next_id": "48",
&"text": "😫",
