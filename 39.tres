},
"30": {
&"character": "Paige",
&"id": "30",
&"next_id": "34",
&"text": "Great! Now we've established the obvious 😋😋",
&"type": "dialogue"
},
"31": {
&"id": "31",
&"next_id": "32",
&"text": "I like Naomi how she is",
&"type": "response"
},
"32": {
&"character": "Player",
&"id": "32",
&"next_id": "33",
&"text": "I like Naomi how she is",
&"type": "dialogue"
},
"33": {
&"character": "Paige",
&"id": "33",
&"next_id": "34",
&"text": "Ugh not you toooo 💀💀💀",
&"type": "dialogue"
},
"34": {
&"character": "Paige",
&"id": "34",
&"next_id": "35",
&"text": "Anyway hurry up",
&"type": "dialogue"
},
"35": {
&"character": "Paige",
&"id": "35",
&"next_id": "36",
&"text": "I have to hang out with a girlfriend in an hour and I want to dress up for the occassion",
&"type": "dialogue"
},
"36": {
&"character": "Paige",
&"id": "36",
&"next_id": "37",
&"text": "And I need to do my nails",
&"type": "dialogue"
},
"37": {
&"character": "Paige",
&"id": "37",
&"next_id": "38",
&"text": "And go shopping for some new shoes",
&"type": "dialogue"
},
"38": {
&"character": "Paige",
&"id": "38",
&"next_id": "39",
&"text": "Oh and this new outfit I ordered is arriving today, so you're gonna carry them for me right? 😇",
&"type": "dialogue"
},
"39": {
&"character": "Player",
&"id": "39",
&"next_id": "40",
&"text": "Wha- hold on 😵‍💫",
