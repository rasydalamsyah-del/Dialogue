&"character": "Paige",
&"id": "109",
&"next_id": "110",
&"text": "When the Sorority turned their backs on me, she never did 😇",
&"type": "dialogue"
},
"11": {
&"character": "Paige",
&"id": "11",
&"next_id": "12",
