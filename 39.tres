},
"23": {
&"character": "Paige",
&"id": "23",
&"next_id": "24",
&"text": "Anyway",
&"type": "dialogue"
},
"24": {
&"character": "Paige",
&"id": "24",
&"next_id": "25",
&"text": "That Naomi girl is such a boor with all this scheduling and boring events",
&"type": "dialogue"
},
"25": {
&"character": "Paige",
&"id": "25",
&"next_id": "26",
&"text": "How can a girl like her be so pretty yet so... 🥱🥱🥱",
