"128": {
&"character": "Paige",
&"id": "128",
&"next_id": "129",
&"text": "Since I'm not in the Sorority anymore, I'll need my own personal pocket boy 😘",
&"type": "dialogue"
},
"129": {
&"character": "Paige",
&"id": "129",
&"next_id": "130",
&"text": "You'll have to be on call anytime I need you for shopping",
&"type": "dialogue"
},
"13": {
&"character": "Paige",
&"id": "13",
&"next_id": "14",
&"text": "Ugh, don't be so hung up on that",
&"type": "dialogue"
},
"130": {
&"character": "Paige",
&"id": "130",
&"next_id": "131",
&"text": "Pick up my packages, sort my mail, do my groceries and laundry, buy my make up, check sales for me",
&"type": "dialogue"
},
"131": {
&"character": "Paige",
&"id": "131",
&"next_id": "132",
&"text": "Aaaand run some errands for me on campus",
&"type": "dialogue"
},
"132": {
&"character": "Paige",
&"id": "132",
&"next_id": "133",
&"text": "🤝",
&"type": "dialogue"
},
"133": {
&"character": "Player",
&"id": "133",
&"next_id": "134",
&"text": "That's a lot of stuff 😱",
&"type": "dialogue"
},
"134": {
&"character": "Paige",
&"id": "134",
&"next_id": "135",
&"text": "🤭",
&"type": "dialogue"
},
"135": {
&"character": "Paige",
&"id": "135",
&"next_id": "136",
&"text": "Oh and one last thing",
&"type": "dialogue"
},
"136": {
&"character": "Player",
&"id": "136",
&"next_id": "137",
&"text": "😩",
&"type": "dialogue"
},
"137": {
&"character": "Paige",
&"id": "137",
&"next_id": "138",
&"text": "It's been just a little boring since I moved to this area",
&"type": "dialogue"
},
