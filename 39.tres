},
"139": {
&"character": "Paige",
&"id": "139",
&"next_id": "140",
&"text": "It's just a teensy bit lonely",
&"type": "dialogue"
},
"14": {
&"character": "Paige",
&"id": "14",
&"next_id": "15",
&"text": "We'll improvise... a lot 😜",
&"type": "dialogue"
},
"140": {
&"character": "Paige",
&"id": "140",
&"next_id": "141",
&"text": "If you'll keep a girl company, that'd be nice",
