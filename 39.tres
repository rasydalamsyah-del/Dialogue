},
"4": {
&"character": "Paige",
&"id": "4",
&"next_id": "5",
&"text": "Heeellooo",
&"type": "dialogue"
},
"40": {
&"character": "Player",
&"id": "40",
&"next_id": "41",
&"text": "You want me to just follow you around all day?",
&"type": "dialogue"
},
"41": {
&"character": "Paige",
&"id": "41",
&"next_id": "42",
&"text": "Duh",
