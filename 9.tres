raw_text = "~ start
do Story.set_location(\"college_square_gardens\")
Mabel: img: mabel/69
Mabel: *poke*
Mabel: *poke poke*
- *poke* [#trust]
	set Story.mabel_trust += 1
	Player: *poke*
	Mabel: Eep! 🥰
	Mabel: How dare you!!
	Player: You started it
	Mabel: Nuh uh. Prove it.
	Mabel: 😇
- *bite* [#lust]
	set Story.mabel_desire += 1
	Player: *bite*
	Mabel: Gah my finger!!
	Mabel: What was that for!? 😂
	Player: Idk, you looked tasty 😋
	Mabel: Jeez such a boy thing to say 😳
	- You saying there are more boys that want to taste you? [#distrust]
		set Story.mabel_trust -= 1
		Player: You saying there are more boys that want to taste you?
		Mabel: Huh!?
		Mabel: Nooo!!
		Mabel: That's not what I meant at all
		Player: 😌
		Mabel: 😩
		Mabel: They wouldn't like me anyway, I taste like doodoo!!
		Player: We can put it to the test 😏
		Mabel: Shush! Nobody gets to bite me 😣
	- Guilty as charged [#trust]
		set Story.mabel_trust += 1
		Player: Guilty as charged
		Mabel: Hmph, I knew it 😏
		Mabel: Maybe I'll let you try 🥰
		Mabel: But only a little and you have to be gentle hehe
- 😛?
	Player: 😛?
	Mabel: Heyy
	Mabel: Pshht you're no fun 😂
	Player: Hey! I'm doing my best lol
	Mabel: 😗
Mabel: Ready for another week?
Mabel: Studies are starting to get more serious!
Player: Don't remind me 😫
Mabel: 🤭
Mabel: C'mon babe, I believe in you
Mabel: My boyfriend is capable of anything 🩷
Player: 😊
Player: What are you up to?
Mabel: Just walking to class now!
Mabel: img: mabel/70
Mabel: Here's a little peek haha
Mabel: What about you?
Player: Getting ready right now
if Story.mabel_desire > 0:
	Mabel: You should send me a pic of you sometimes 👀
	Mabel: Shirt is optional
	Player: Ooh, is that what you're into now?
	Mabel: N-no! 😇
	Mabel: I'm a good girl!
else:
	Mabel: I somehow miss you already
	Mabel: Honestly I don't think I'd be satisfied until we're literally living in the same room 🤭
	Mabel: I'd want you to be able to reach out and pull me in for a hug whenever
	Mabel: 🥰
	Mabel: Omg I feel so jealous of girls who have that available to them
	Player: Wow, that sounds amazing
	Player: Private Mabel access 😍
	Mabel: Oh jeez, don't say it that way or I'm gonna blush lol 🫣
Mabel: Hurry up lazy butt or you're gonna be late! 😂
if Story.mabel_trust < 50:
	Mabel: Hold on one second babe 😅
	Mabel: Thought: Who...?
	do echo_set([\"71\"])
	Mabel: sfx: none: Yes?
	do heart(1)
	Player: Sure tyt
	Mabel: sfx: none: Oh umm hello
	Mabel: sfx: none: No I don't dye it
	Mabel: sfx: none: Thanks hehe
	Mabel: sfx: none: Yeah, usually alone
	Mabel: sfx: none: My what?
	Player: Babe?
	Mabel: Thought: Should I... I guess it's okay
	Mabel: sfx: none: Sure, I guess 
	Mabel: sfx: none: Is that okay?
	Mabel: sfx: none: Okay then
	Mabel: sfx: none: See you too
	Mabel: Thought: Did I just... give him my... Social??
	Player: You still there?
	do echo_clear()
	Mabel: Thought: Eep!! What do I say..
	Mabel: Thought: I can't tell babe but I'll block him later
	Mabel: Thought: Yeah that's what I'll do!
	Mabel: Thought: I don't want comments on my profile
	Mabel: Thought: I'll have to remember
	Mabel: Mhmm!!
	Mabel: Yeah I'm here, sorry I tripped on a rock 😁
	Mabel: Why? Did you need something??
	Player: No just wondering where you went haha
	Player: You okay?
	Mabel: Totally fine! Not a scratch
	Mabel: Okay now I'm laate
	Mabel: love you gotta run bye!
	do heart(0)
	do Story.set_location(\"lecture_hall\")
else:
	Mabel: The weather is so nice today
	Mabel: Wish we could walk together hehe
	Mabel: I'd grab your arm all tight 😍
	do Story.set_location(\"lecture_hall\")
	Mabel: Would you like that?
	- I would
		Player: I would
		Mabel: Good 😘
	- I'd love that [#love]
		set Story.mabel_desire -= 1
		Player: I'd love that
		Mabel: Right answer
		Mabel: And for that, you get a little extra love today 🥰
		Mabel: img: mabel/72
	Mabel: Wow, today's super busy
	Mabel: Everyone's scrambling around hehe
	Mabel: Better keep up with me babe 😁
	Mabel: I'm gonna be the top student! 🩷
	Player: I believe that!
	Mabel: Make sure you study hard too 😘
	Mabel: Okay class is gonna start cutie! Bye!
Player: Bye!
do social_post(\"erika_formcry\")
=> END"
metadata/dialogue_manager_version = "3.7.1"
