&"next_id": "105",
&"text": "img: suzanna/11",
&"type": "dialogue"
},
"105": {
&"id": "105",
&"next_id": "106",
&"responses": PackedStringArray("105", "108"),
&"text": "It's lonely for me too",
&"type": "response"
},
"106": {
&"character": "Player",
&"id": "106",
&"next_id": "107",
&"text": "It's lonely for me too",
&"type": "dialogue"
},
"107": {
&"character": "Suzanna",
&"id": "107",
&"next_id": "111",
&"text": "😳",
&"type": "dialogue"
},
"108": {
&"id": "108",
&"next_id": "109",
&"text": "Maybe I can cheer you up",
&"type": "response"
},
"109": {
&"character": "Player",
&"id": "109",
&"next_id": "110",
&"text": "Maybe I can cheer you up",
&"type": "dialogue"
},
"11": {
&"character": "Suzanna",
&"id": "11",
&"next_id": "12",
&"text": "Don't worry 😊",
&"type": "dialogue"
},
"110": {
&"character": "Suzanna",
&"id": "110",
&"next_id": "111",
&"text": "Maybe.. you can",
&"type": "dialogue"
},
"111": {
&"character": "Suzanna",
&"id": "111",
&"next_id": "112",
&"text": "Maybe you could come to my room, just... for a little bit",
&"type": "dialogue"
},
"112": {
&"character": "Suzanna",
&"id": "112",
&"next_id": "113",
&"text": "For tonight, we can be a little less lonely together?",
&"type": "dialogue"
},
"113": {
&"character": "Player",
&"id": "113",
&"next_id": "114",
&"text": "I'd like that",
&"type": "dialogue"
},
"114": {
&"character": "Suzanna",
&"id": "114",
&"next_id": "115",
&"text": "I don't want the night to end on such a sour note",
&"type": "dialogue"
},
"115": {
&"character": "Suzanna",
&"id": "115",
&"next_id": "116",
&"text": "Give me some time to prepare",
&"type": "dialogue"
},
"116": {
&"character": "Player",
&"id": "116",
&"next_id": "117",
&"text": "Prepare what?",
&"type": "dialogue"
},
"117": {
&"character": "Suzanna",
&"id": "117",
&"next_id": "118",
&"text": "This",
&"type": "dialogue"
},
"118": {
&"character": "Suzanna",
&"id": "118",
&"next_id": "119",
&"text": "img: suzanna/12",
&"type": "dialogue"
},
"119": {
&"character": "Player",
&"id": "119",
&"next_id": "120",
&"text": "😳",
&"type": "dialogue"
},
"12": {
&"character": "Suzanna",
&"id": "12",
&"next_id": "13",
&"text": "I've already arranged two separate rooms for us",
&"type": "dialogue"
},
"120": {
&"character": "Suzanna",
&"id": "120",
&"next_id": "121",
&"text": "In about 15 minutes, knock 3 times on my door",
&"type": "dialogue"
},
"121": {
&"character": "Player",
&"id": "121",
&"next_id": "130",
&"text": "Okay",
&"type": "dialogue"
},
"122": {
&"id": "122",
&"next_id": "123",
&"text": "I'm glad you had a good time",
&"type": "response"
},
"123": {
&"character": "Player",
&"id": "123",
&"next_id": "124",
&"text": "I'm glad you had a good time",
&"type": "dialogue"
},
"124": {
&"character": "Suzanna",
&"id": "124",
&"next_id": "125",
&"text": "I really did!",
&"type": "dialogue"
},
"125": {
&"character": "Suzanna",
&"id": "125",
&"next_id": "126",
&"text": "You've uplifted my spirits and gave me some much needed confidence",
&"type": "dialogue"
},
"126": {
&"character": "Suzanna",
&"id": "126",
&"next_id": "127",
&"text": "This should also help hold off the rumors for the meanwhile",
&"type": "dialogue"
},
"127": {
&"character": "Player",
&"id": "127",
&"next_id": "128",
&"text": "Glad to help",
&"type": "dialogue"
},
"128": {
&"character": "Suzanna",
&"id": "128",
&"next_id": "129",
&"text": "Good night sweetheart!",
&"type": "dialogue"
},
"129": {
&"character": "Player",
&"id": "129",
&"next_id": "130",
&"text": "Good night 🙂",
&"type": "dialogue"
},
"13": {
&"character": "Suzanna",
&"id": "13",
&"next_id": "14",
&"text": "You're free to leave after arriving, or if you'd like, you can stay in the fancy room!",
&"type": "dialogue"
},
