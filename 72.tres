"14": {
&"character": "Suzanna",
&"id": "14",
&"next_id": "15",
&"text": "But no need to feel like you have to be present around me",
&"type": "dialogue"
},
"15": {
&"character": "Player",
&"id": "15",
&"next_id": "16",
&"text": "Is this for the rumor business?",
&"type": "dialogue"
},
"16": {
&"character": "Suzanna",
&"id": "16",
&"next_id": "17",
&"text": "Quite ☹️ I found out one of my colleagues is on a date in the same restaurant 😓",
&"type": "dialogue"
},
"17": {
&"character": "Suzanna",
&"id": "17",
&"next_id": "18",
&"text": "So I thought this was the best opportunity to create the impression that things were going \"well\" 😊",
&"type": "dialogue"
},
"18": {
&"character": "Player",
&"id": "18",
&"next_id": "19",
&"text": "Ah, must mean a lot to you",
&"type": "dialogue"
},
"19": {
&"character": "Suzanna",
&"id": "19",
&"next_id": "20",
&"text": "Sorry for dragging you into my personal affairs, I must seem very unprofessional",
&"type": "dialogue"
},
"2": {
&"character": "Player",
&"id": "2",
&"next_id": "3",
&"text": "Hey, almost ready!",
&"type": "dialogue"
},
"20": {
&"character": "Suzanna",
&"id": "20",
&"next_id": "21",
&"text": "But I don't know how I could ever repay you",
&"type": "dialogue"
},
