"100": {
&"character": "Suzanna",
&"id": "100",
&"next_id": "101",
&"text": "That's a bit of the alcohol talking, excuse me for being so frank",
&"type": "dialogue"
},
"101": {
&"character": "Player",
&"id": "101",
&"next_id": "102",
&"text": "No, it's okay!",
&"type": "dialogue"
},
"102": {
&"character": "Suzanna",
&"id": "102",
&"next_id": "103",
&"text": "I'm just feeling really lonely",
&"type": "dialogue"
},
