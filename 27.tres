&"character": "Suzanna",
&"id": "12",
&"next_id": "13",
&"text": "Recently, I find myself having a lot more free time so I'm always around!",
&"type": "dialogue"
},
"120": {
&"character": "Mabel",
&"id": "120",
&"next_id": "121",
&"text": "Nice to meet you 😀",
&"type": "dialogue"
},
