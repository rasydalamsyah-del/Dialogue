&"character": "Paige",
&"id": "113",
&"next_id": "114",
&"text": "I see everyone's already introduced themselves sooo 🥺",
&"type": "dialogue"
},
"114": {
&"character": "Paige",
&"id": "114",
&"next_id": "115",
&"text": "Let me tell you all about me 🥰",
&"type": "dialogue"
},
