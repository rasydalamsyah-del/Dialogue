&"character": "Paige",
&"id": "118",
&"next_id": "119",
&"text": "I am interested in fashion, cosplaying, pictures of me (duh), and social scene",
&"type": "dialogue"
},
"119": {
&"character": "Caleb",
&"id": "119",
&"next_id": "120",
&"text": "Hi",
&"type": "dialogue"
},
