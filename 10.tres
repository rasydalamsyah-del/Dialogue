raw_text = "~ start
do Story.set_location(\"mabels_room\")
Nina: Hey biatch
Nina: Remember me?
Player: How could I forget?
Nina: Hah, you're really something y'know?
Nina: Anyway
Nina: Look
Nina: Gonna try to be \"nice\" and throw you a bone here buddy
Nina: Just let go of Maple while you can
Nina: Find some other girl, there's like dozens of them or some shit
Nina: Spare yourself the headache, y'know I've seen it before
Nina: Ain't pretty bucko
- I won't give up on her
	Player: I won't give up on her
	Player: She's my girlfriend
	Nina: Awwh so sad
	Nina: You're just another one of those lost boys with something you shouldn't have
	Nina: We're just here to collect what belongs to us
	Nina: Don't say I didn't warn you loser
	Nina: Pathetic
- Wow, you have a heart?
	Player: Wow, you have a heart?
	Nina: You don't even realize how much you piss me off
	- Thanks
		Player: Thanks
		Nina: Whatever dude
		Nina: I have better things to do than to play your stupid games
	- Glad you feel so strongly about me [#blackheart]
		set Story.black_heart += 1
		Player: Glad you feel so strongly about me
		Nina: FUCK. OFF.
		Nina: I better not run into you or you'll fuckin' see
		Nina: I'll wipe that grin off your face
		Player: Great, pick you up at 7?
		Nina: 🖕
		Nina: img: nina/11
=> END
"
metadata/dialogue_manager_version = "3.7.1"
