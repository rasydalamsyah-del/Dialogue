"101": {
&"character": "Mabel",
&"id": "101",
&"next_id": "102",
&"text": "Thought: Phew, it felt like he wanted to invite me somewhere",
&"type": "dialogue"
},
"102": {
&"character": "Mabel",
&"id": "102",
&"next_id": "103",
&"text": "Thought: But what did he mean by \"keep trying\"? Is he seriously going to follow me around",
&"type": "dialogue"
},
"103": {
&"character": "Mabel",
&"id": "103",
&"next_id": "104",
&"text": "Thought: That was WAY too scary and I don't want to worry babe",
&"type": "dialogue"
},
