},
"30": {
&"id": "30",
&"next_id": "31",
&"tags": PackedStringArray("distrust"),
&"text": "With that many complaint about me, you sure you want me around more? 😁",
&"type": "response"
},
"31": {
&"character": "Player",
&"id": "31",
&"next_id": "32",
&"text": "With that many complaint about me, you sure you want me around more? 😁",
&"type": "dialogue"
},
"32": {
&"character": "Mabel",
&"id": "32",
&"next_id": "33",
&"text": "Of course silly",
&"type": "dialogue"
},
"33": {
&"character": "Mabel",
&"id": "33",
&"next_id": "34",
&"text": "I'll complain about you my whole life but I wouldn't want anyone else hehe",
&"type": "dialogue"
},
"34": {
&"character": "Mabel",
&"id": "34",
&"next_id": "35",
