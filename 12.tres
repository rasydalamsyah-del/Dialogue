&"character": "Mabel",
&"id": "38",
&"next_id": "39",
&"text": "Seriously she was so grateful 🥹",
&"type": "dialogue"
},
"39": {
&"character": "Player",
&"id": "39",
&"next_id": "40",
&"text": "I guess you can call me dad now 😌",
&"type": "dialogue"
},
