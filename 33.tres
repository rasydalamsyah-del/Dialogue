},
"26": {
&"character": "Naomi",
&"id": "26",
&"next_id": "27",
&"text": "That's true",
&"type": "dialogue"
},
"27": {
&"character": "Naomi",
&"id": "27",
&"next_id": "28",
&"text": "Anyway, Mabel could you help out?",
&"type": "dialogue"
},
"28": {
&"character": "Mabel",
&"id": "28",
&"next_id": "29",
&"text": "Wh- me!? 😳",
&"type": "dialogue"
},
"29": {
&"character": "Naomi",
&"id": "29",
&"next_id": "30",
&"text": "Yeah, you're a charming girl 😊",
&"type": "dialogue"
},
"3": {
&"character": "Naomi",
&"id": "3",
&"next_id": "4",
&"text": "Good morning everyone!",
&"type": "dialogue"
},
"30": {
&"character": "Naomi",
&"id": "30",
&"next_id": "31",
&"text": "I'm sure they'd be happy to accept you as the model",
&"type": "dialogue"
},
"31": {
&"character": "Mabel",
&"id": "31",
&"next_id": "32",
&"text": "But I've never done anything like that before.. 🙈",
&"type": "dialogue"
},
"32": {
&"character": "Naomi",
&"id": "32",
&"next_id": "33",
&"text": "I wouldn't have picked you if I didn't think you were right for the job!",
&"type": "dialogue"
},
"33": {
&"id": "33",
&"next_id": "34",
&"responses": PackedStringArray("33", "35"),
&"text": "Don't worry too much babe!",
