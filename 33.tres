},
"45": {
&"character": "Naomi",
&"id": "45",
&"next_id": "46",
&"text": "Perfect!",
&"type": "dialogue"
},
"46": {
&"character": "Mabel",
&"id": "46",
&"next_id": "47",
&"text": "Will I be going alone? 😳",
&"type": "dialogue"
},
"47": {
&"character": "Naomi",
&"id": "47",
&"next_id": "48",
&"text": "Actually the club is quite close to your boyfriend's campus!",
&"type": "dialogue"
},
"48": {
&"character": "Naomi",
&"id": "48",
&"next_id": "49",
&"text": "I'm sure he can help and take the photos for the club!",
&"type": "dialogue"
},
"49": {
&"character": "Mabel",
&"id": "49",
&"next_id": "50",
&"text": "Wow lucky me! 🥰",
&"type": "dialogue"
},
"5": {
&"character": "Naomi",
&"id": "5",
&"next_id": "6",
&"text": "We have just a few announcements and some work for any willing volunteers!",
&"type": "dialogue"
},
"50": {
&"character": "Player",
&"id": "50",
&"next_id": "76",
&"text": "Lucky me too!",
