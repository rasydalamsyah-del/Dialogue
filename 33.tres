"22": {
&"character": "Naomi",
&"id": "22",
&"next_id": "23",
&"text": "First I'll need a volunteer for a photoshoot by another club",
&"type": "dialogue"
},
"23": {
&"character": "Naomi",
&"id": "23",
&"next_id": "24",
&"text": "They would like a girl on some of their advertisements and they requested me funnily enough 😅",
&"type": "dialogue"
},
"24": {
&"character": "Naomi",
&"id": "24",
&"next_id": "25",
&"text": "But my schedule is super packed this week so is @Paige around?",
&"type": "dialogue"
},
"25": {
&"character": "Player",
&"id": "25",
&"next_id": "26",
&"text": "Maybe she has class?",
