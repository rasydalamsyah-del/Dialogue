"52": {
&"character": "Naomi",
&"id": "52",
&"next_id": "53",
&"text": "I'll be sending you to work with the weekend club",
&"type": "dialogue"
},
"53": {
&"character": "Naomi",
&"id": "53",
&"next_id": "54",
&"text": "They run the weekend night club parties, they're a pretty big deal!",
&"type": "dialogue"
},
"54": {
&"character": "Mabel",
&"id": "54",
&"next_id": "55",
&"text": "Wow really?",
&"type": "dialogue"
},
"55": {
&"character": "Naomi",
&"id": "55",
&"next_id": "56",
&"text": "Mhmm, their usual cover girl is really sick so they need someone to fill in",
&"type": "dialogue"
},
"56": {
&"character": "Naomi",
&"id": "56",
&"next_id": "57",
&"text": "They are advertising one of their new club outfits for sale",
&"type": "dialogue"
},
"57": {
&"character": "Mabel",
&"id": "57",
&"next_id": "58",
&"text": "Oh wow.. Uhm. Okay!",
&"type": "dialogue"
},
"58": {
&"character": "Mabel",
&"id": "58",
&"next_id": "59",
&"text": "I hope they don't need me to dance",
&"type": "dialogue"
},
"59": {
&"character": "Naomi",
&"id": "59",
&"next_id": "60",
&"text": "Haha, it's just a photoshoot. I don't think they'll expect you to do anything more than that",
&"type": "dialogue"
},
"6": {
&"character": "Mabel",
&"id": "6",
&"next_id": "7",
&"text": "👋👀",
&"type": "dialogue"
},
"60": {
&"character": "Mabel",
&"id": "60",
&"next_id": "61",
&"text": "Oh okay, I guess I could do that 😊",
&"type": "dialogue"
},
"61": {
&"character": "Mabel",
&"id": "61",
&"next_id": "62",
&"text": "Will I be going alone? 😳",
&"type": "dialogue"
},
"62": {
&"character": "Naomi",
&"id": "62",
&"next_id": "63",
&"text": "Actually the club is quite close to Caleb's building!",
