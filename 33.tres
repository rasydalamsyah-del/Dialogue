},
"40": {
&"character": "Naomi",
&"id": "40",
&"next_id": "41",
&"text": "I'll be sending you to work with the tennis club",
&"type": "dialogue"
},
"41": {
&"character": "Mabel",
&"id": "41",
&"next_id": "42",
&"text": "Tennis club?",
&"type": "dialogue"
},
"42": {
&"character": "Naomi",
&"id": "42",
&"next_id": "43",
&"text": "Yes! They'd like a cover girl for their club posters since they're having trouble attracting girls to the club",
&"type": "dialogue"
},
"43": {
&"character": "Naomi",
&"id": "43",
&"next_id": "44",
&"text": "They want to show it's for everyone",
&"type": "dialogue"
},
"44": {
&"character": "Mabel",
&"id": "44",
&"next_id": "45",
&"text": "Oh I see, I guess that's nice",
