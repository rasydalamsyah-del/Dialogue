raw_text = "~ start
do Story.set_location(\"mabels_room\")
Mabel: img: mabel/87
Mabel: Psssst
Mabel: Heya!
Player: Ready to go out?
Mabel: Mhmm!
Mabel: But I'm still thinking about where we should go!
Player: You're still in PJs?
Mabel: Yeah!
Player: It's past noon
Mabel: Hey I was having a lazy day 🫠
Player: I'll be on my way soon 😄
Mabel: Gah!!
Mabel: Oki dokes!! Gotta change
Mabel: I want today to be extra special 🤭
Mabel: Hmmmmm
Mabel: img: mabel/88
Mabel: OMG
Mabel: I totally know! 🤩
Mabel: I found something in one of the clothing boxes that I wanted to try on 😇
Player: Why not wear it for class?
Mabel: It's not that kind of thing silly 🤭
Mabel: Thought: Well... now that I think about it, some girls DO come to college almost dressed in a bikini
Player: So where are we going?
Mabel: I want it to be a surprise!!
Mabel: Uhm... can you bring swimming shorts? 🫣
Player: Not much of a surprise anymore haha
Mabel: SHH, just grab them and don't think about it 😌
Player: 😂👍
Mabel: ☺️
if Story.has_flag(\"LOVE\") && Story.pink_heart >= 3:
	Mabel: PinkThought: This is it Mabel!
	Mabel: PinkThought: You gotta lean in and flutter your eyes!
	Mabel: PinkThought: That's what the girls mag on social scene says anyway
Player: I'll be there in an hour then!
Mabel: Okay!
Mabel: See you soon!
if Story.has_flag(\"LOVE\") && Story.pink_heart >= 3:
	do mabel_kissed(\"Player\")
	set PhoneUnlocks.leak = \"naomi2\"
=> END"
metadata/dialogue_manager_version = "3.7.1"
