"13": {
&"character": "Naomi",
&"id": "13",
&"next_id": "14",
&"text": "We'll play some of our old club games since we're big enough to now",
&"type": "dialogue"
},
"14": {
&"character": "Player",
&"id": "14",
&"next_id": "15",
&"text": "What kind of games?",
