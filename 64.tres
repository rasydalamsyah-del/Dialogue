},
"20": {
&"character": "Caleb",
&"id": "20",
&"next_id": "21",
&"text": "🙉",
&"type": "dialogue"
},
"21": {
&"character": "Naomi",
&"id": "21",
&"next_id": "22",
&"text": "It's a little party game me and Caleb cooked up",
&"type": "dialogue"
},
"22": {
&"character": "Naomi",
&"id": "22",
&"next_id": "23",
&"text": "One participant goes into the photography dark room",
&"type": "dialogue"
},
"23": {
&"character": "Naomi",
&"id": "23",
&"next_id": "24",
&"text": "and the rest of us vote on one of the others to go in to kiss that person",
