},
"16": {
&"character": "Naomi",
&"id": "16",
&"next_id": "17",
&"text": "All sorts!",
&"type": "dialogue"
},
"17": {
&"character": "Naomi",
&"id": "17",
&"next_id": "18",
&"text": "One of my personal favorites is the dark room game 🤭",
&"type": "dialogue"
},
