&"character": "Naomi",
&"id": "26",
&"next_id": "27",
&"text": "Mhmm!",
&"type": "dialogue"
},
"27": {
&"character": "Naomi",
&"id": "27",
&"next_id": "28",
&"text": "Naturally so the first person doesn't know who their partner is",
&"type": "dialogue"
},
"28": {
&"character": "Naomi",
&"id": "28",
&"next_id": "29",
&"text": "But that makes the kiss more exciting doesn't it? 😊",
&"type": "dialogue"
},
"29": {
&"character": "Naomi",
&"id": "29",
&"next_id": "30",
&"text": "We'll make sure everyone gets a chance",
&"type": "dialogue"
},
