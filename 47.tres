&"id": "76",
&"next_id": "77",
&"text": "I've never considered dating a younger man before..",
&"type": "dialogue"
},
"77": {
&"character": "Suzanna",
&"id": "77",
&"next_id": "78",
&"text": "Ahem.. I am certainly getting off track here",
&"type": "dialogue"
},
"78": {
&"character": "Suzanna",
&"id": "78",
&"next_id": "79",
&"text": "If you would have me then, I accept",
&"type": "dialogue"
},
"79": {
&"character": "Suzanna",
&"id": "79",
&"next_id": "80",
&"text": "It's the least I can do for such a kind and forward young man",
&"type": "dialogue"
},
"8": {
&"character": "Suzanna",
&"id": "8",
&"next_id": "9",
&"text": "Thank you so very much for offering your assistance 🙂",
&"type": "dialogue"
},
"80": {
&"character": "Player",
&"id": "80",
&"next_id": "81",
&"text": "Sounds good 😁",
&"type": "dialogue"
},
"81": {
&"character": "Suzanna",
&"id": "81",
&"next_id": "82",
&"text": "I wish we had a moment to get to know each other just a little better before but my schedule is quite tight",
&"type": "dialogue"
},
"82": {
&"character": "Suzanna",
&"id": "82",
&"next_id": "83",
&"text": "Or that I could pay you back somehow",
&"type": "dialogue"
},
"83": {
&"character": "Suzanna",
&"id": "83",
&"next_id": "84",
&"text": "And it doesn't help that today's quite a hot day",
&"type": "dialogue"
},
"84": {
