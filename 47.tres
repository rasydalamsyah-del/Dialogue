&"character": "Player",
&"id": "41",
&"next_id": "44",
&"text": "What would that achieve though?",
&"type": "dialogue"
},
"42": {
&"id": "42",
&"next_id": "43",
&"text": "What rumors are these going to help with?",
&"type": "response"
