"10": {
&"character": "Caleb",
&"id": "10",
&"next_id": "11",
&"text": "I like to try to snapshot them in that moment",
&"type": "dialogue"
},
"100": {
&"character": "Caleb",
&"id": "100",
&"next_id": "101",
&"text": "You have the other ones btw?",
&"type": "dialogue"
},
"101": {
&"character": "Player",
&"id": "101",
&"next_id": "102",
&"text": "Oh right",
&"type": "dialogue"
},
"102": {
&"character": "Player",
&"id": "102",
&"next_id": "103",
&"text": "img: alice/3",
&"type": "dialogue"
},
"103": {
&"character": "Caleb",
&"id": "103",
&"next_id": "104",
&"text": "This one came out nicely too!",
&"type": "dialogue"
},
"104": {
&"character": "Caleb",
&"id": "104",
&"next_id": "105",
&"text": "Not gonna lie, I kinda wanted to take a swim after seeing this haha",
&"type": "dialogue"
},
"105": {
&"character": "Player",
&"id": "105",
&"next_id": "106",
&"text": "The weather was great!",
&"type": "dialogue"
},
"106": {
&"character": "Caleb",
&"id": "106",
&"next_id": "107",
&"text": "Yep!",
&"type": "dialogue"
},
"107": {
&"character": "Caleb",
&"id": "107",
&"next_id": "108",
&"text": "Show me that last one",
&"type": "dialogue"
},
"108": {
&"character": "Player",
&"id": "108",
&"next_id": "109",
&"text": "img: alice/4",
&"type": "dialogue"
},
"109": {
&"character": "Player",
&"id": "109",
&"next_id": "110",
&"text": "Here",
&"type": "dialogue"
},
"11": {
&"character": "Player",
&"id": "11",
&"next_id": "12",
&"text": "Almost like a wildlife photographer lol",
&"type": "dialogue"
},
"110": {
&"character": "Caleb",
&"id": "110",
&"next_id": "111",
&"text": "This one's probably the perfect submission",
&"type": "dialogue"
},
"111": {
&"character": "Caleb",
&"id": "111",
&"next_id": "112",
&"text": "Pictures that really make you think are always good",
&"type": "dialogue"
},
"112": {
&"character": "Player",
&"id": "112",
&"next_id": "113",
&"text": "I agree",
&"type": "dialogue"
},
"113": {
&"character": "Player",
&"id": "113",
&"next_id": "114",
&"text": "Were these okay to take though?",
&"type": "dialogue"
},
"114": {
&"character": "Caleb",
&"id": "114",
&"next_id": "115",
&"text": "I'm gonna show the ones I took to Naomi and see if we can somehow cheer Alice up",
&"type": "dialogue"
},
"115": {
&"character": "Caleb",
&"id": "115",
&"next_id": "116",
&"text": "I want her to have a better time in college and these might just clue us in on what we can do for her",
&"type": "dialogue"
},
"116": {
&"character": "Player",
&"id": "116",
&"next_id": "117",
&"text": "That's sounds nice!",
&"type": "dialogue"
},
"117": {
&"character": "Caleb",
&"id": "117",
&"next_id": "118",
&"text": "Thanks 😄 I do what I can to help",
&"type": "dialogue"
},
"118": {
&"character": "Caleb",
&"id": "118",
&"next_id": "119",
&"text": "Alright then",
&"type": "dialogue"
},
"119": {
&"character": "Caleb",
&"id": "119",
&"next_id": "120",
&"text": "You don't have to worry about the application process",
&"type": "dialogue"
},
"12": {
&"character": "Caleb",
&"id": "12",
&"next_id": "13",
&"text": "Exactly!",
&"type": "dialogue"
},
"120": {
&"character": "Caleb",
&"id": "120",
&"next_id": "121",
&"text": "Since we're a pretty small club, I can submit yours directly to Naomi who handles all the paperwork",
&"type": "dialogue"
},
"121": {
&"character": "Player",
&"id": "121",
&"next_id": "122",
&"text": "Wow convenient!",
&"type": "dialogue"
},
"122": {
&"character": "Caleb",
&"id": "122",
&"next_id": "123",
&"text": "delete: What are friends for!",
&"type": "dialogue"
},
"123": {
&"character": "Caleb",
&"id": "123",
&"next_id": "124",
&"text": "Ah didn't want to assume anything but happy to help!",
&"type": "dialogue"
},
"124": {
&"id": "124",
&"next_id": "125",
&"responses": PackedStringArray("124", "130"),
&"text": "I think of you as a friend!",
&"type": "response"
},
