"39": {
&"character": "Caleb",
&"id": "39",
&"next_id": "40",
&"text": "I still can't believe we ran into Alice",
&"type": "dialogue"
},
"4": {
&"character": "Caleb",
&"id": "4",
&"next_id": "5",
&"text": "I'll be there soon",
&"type": "dialogue"
},
"40": {
&"character": "Player",
&"id": "40",
&"next_id": "41",
&"text": "This was that girl that hides out in the Photography Club room right?",
&"type": "dialogue"
},
"41": {
&"character": "Caleb",
&"id": "41",
&"next_id": "42",
&"text": "Yeah 😅",
&"type": "dialogue"
},
"42": {
&"character": "Caleb",
&"id": "42",
&"next_id": "43",
&"text": "Because she gets picked on, poor thing",
&"type": "dialogue"
},
"43": {
&"character": "Caleb",
&"id": "43",
&"next_id": "44",
&"text": "Naomi actually convinced her to join the club",
&"type": "dialogue"
},
"44": {
&"character": "Player",
&"id": "44",
&"next_id": "45",
&"text": "Oh that's interesting",
&"type": "dialogue"
},
"45": {
&"character": "Caleb",
&"id": "45",
&"next_id": "46",
&"text": "Yep so she'll be a new member hopefully!",
&"type": "dialogue"
},
"46": {
&"character": "Caleb",
&"id": "46",
&"next_id": "47",
&"text": "But what a coincidence huh?",
&"type": "dialogue"
},
"47": {
&"character": "Player",
&"id": "47",
&"next_id": "48",
&"text": "Unexpected for sure!",
&"type": "dialogue"
},
"48": {
&"character": "Caleb",
&"id": "48",
&"next_id": "49",
