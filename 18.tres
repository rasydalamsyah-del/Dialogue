},
"128": {
&"character": "Caleb",
&"id": "128",
&"next_id": "129",
&"text": "I can't wait to make this all official so our little band of friends grows!",
&"type": "dialogue"
},
"129": {
&"character": "Caleb",
&"id": "129",
&"next_id": "132",
&"text": "Group chat's been a little quiet lately haha",
&"type": "dialogue"
},
"13": {
&"character": "Caleb",
&"id": "13",
&"next_id": "14",
&"text": "I like to try to understand people and their story and struggles and display them in the work",
&"type": "dialogue"
},
"130": {
&"id": "130",
&"next_id": "131",
&"text": "Thanks!",
&"type": "response"
},
